generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  major        String?
  year         String?
  bio          String?
  rating       Float    @default(0)
  avatar       String?
  createdAt    DateTime @default(now())

  hostedSessions   Session[]       @relation("SessionHost")
  sessionMembers   SessionMember[]
  connectionsFrom  Connection[]    @relation("ConnectionFrom")
  connectionsTo    Connection[]    @relation("ConnectionTo")
  sentMessages     Message[]       @relation("MessageSender")
  receivedMessages Message[]       @relation("MessageReceiver")
}

model Session {
  id              String   @id @default(cuid())
  courseCode      String
  courseName      String
  date            String
  time            String
  location        String
  description     String?
  maxParticipants Int      @default(6)
  status          String   @default("open")
  createdAt       DateTime @default(now())

  host    User   @relation("SessionHost", fields: [hostId], references: [id])
  hostId  String

  members SessionMember[]
}

model SessionMember {
  id        String   @id @default(cuid())
  joinedAt  DateTime @default(now())

  session   Session @relation(fields: [sessionId], references: [id])
  sessionId String

  user   User   @relation(fields: [userId], references: [id])
  userId String
}

model Connection {
  id        String   @id @default(cuid())
  status    String   @default("pending")
  createdAt DateTime @default(now())

  fromUser   User   @relation("ConnectionFrom", fields: [fromUserId], references: [id])
  fromUserId String

  toUser   User   @relation("ConnectionTo", fields: [toUserId], references: [id])
  toUserId String
}

model Message {
  id        String   @id @default(cuid())
  text      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  sender     User   @relation("MessageSender", fields: [senderId], references: [id])
  senderId   String

  receiver   User   @relation("MessageReceiver", fields: [receiverId], references: [id])
  receiverId String

  sessionId String?
}