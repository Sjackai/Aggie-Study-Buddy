generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  major        String?
  year         String?
  bio          String?
  avatar       String?
  isPrivate    Boolean  @default(false)
  createdAt    DateTime @default(now())

  hostedSessions    Session[]         @relation("SessionHost")
  sessionMembers    SessionMember[]
  connectionsFrom   Connection[]      @relation("ConnectionFrom")
  connectionsTo     Connection[]      @relation("ConnectionTo")
  sentMessages      Message[]         @relation("MessageSender")
  receivedMessages  Message[]         @relation("MessageReceiver")
  kudosGiven        Kudos[]           @relation("KudosFrom")
  kudosReceived     Kudos[]           @relation("KudosTo")
  groupChatMembers  GroupChatMember[]
  groupChatMessages GroupChatMessage[]
  preferences       UserPreferences?
}

model Session {
  id              String   @id @default(cuid())
  courseCode      String
  courseName      String
  date            String
  time            String
  location        String
  description     String?
  maxParticipants Int      @default(6)
  status          String   @default("open")
  tags            String[]
  createdAt       DateTime @default(now())

  host      User            @relation("SessionHost", fields: [hostId], references: [id])
  hostId    String
  members   SessionMember[]
  kudos     Kudos[]
  groupChat GroupChat?
}

model SessionMember {
  id        String   @id @default(cuid())
  joinedAt  DateTime @default(now())

  session   Session @relation(fields: [sessionId], references: [id])
  sessionId String

  user   User   @relation(fields: [userId], references: [id])
  userId String
}

model Connection {
  id        String   @id @default(cuid())
  status    String   @default("pending")
  createdAt DateTime @default(now())

  fromUser   User   @relation("ConnectionFrom", fields: [fromUserId], references: [id])
  fromUserId String

  toUser   User   @relation("ConnectionTo", fields: [toUserId], references: [id])
  toUserId String
}

model Message {
  id        String   @id @default(cuid())
  text      String
  read      Boolean  @default(false)
  isRequest Boolean  @default(false)
  accepted  Boolean  @default(false)
  declined  Boolean  @default(false)
  createdAt DateTime @default(now())

  sender     User   @relation("MessageSender", fields: [senderId], references: [id])
  senderId   String

  receiver   User   @relation("MessageReceiver", fields: [receiverId], references: [id])
  receiverId String

  sessionId String?
}

model Kudos {
  id        String   @id @default(cuid())
  tag       String
  createdAt DateTime @default(now())

  fromUser   User   @relation("KudosFrom", fields: [fromUserId], references: [id])
  fromUserId String

  toUser   User   @relation("KudosTo", fields: [toUserId], references: [id])
  toUserId String

  session   Session @relation(fields: [sessionId], references: [id])
  sessionId String
}

model GroupChat {
  id        String   @id @default(cuid())
  name      String
  sessionId String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  session  Session           @relation(fields: [sessionId], references: [id])
  members  GroupChatMember[]
  messages GroupChatMessage[]
}

model GroupChatMember {
  id              String    @id @default(cuid())
  joinedAt        DateTime  @default(now())
  leftAt          DateTime?
  approved        Boolean   @default(true)
  lastRead        DateTime  @default(now())
  rejoinRequested Boolean   @default(false)

  groupChat   GroupChat @relation(fields: [groupChatId], references: [id])
  groupChatId String

  user   User   @relation(fields: [userId], references: [id])
  userId String
}

model GroupChatMessage {
  id        String   @id @default(cuid())
  text      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  groupChat   GroupChat @relation(fields: [groupChatId], references: [id])
  groupChatId String

  sender   User   @relation(fields: [senderId], references: [id])
  senderId String
}

model UserPreferences {
  id         String   @id @default(cuid())
  studyStyle String?
  studyTime  String?
  goals      String?
  courses    String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique
}